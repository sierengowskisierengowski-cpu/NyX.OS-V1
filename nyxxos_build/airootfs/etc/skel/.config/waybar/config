{
    "layer": "top",
    "position": "bottom",
    "height": 36,
    "spacing": 0,

    "modules-left": [
        "custom/launcher",
        "custom/search",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "tray",
        "network",
        "pulseaudio",
        "battery",
        "clock"
    ],

    "custom/launcher": {
        "format": "  NyX.x ",
        "on-click": "wofi --show drun",
        "on-click-right": "wofi --show run",
        "tooltip": false
    },

    "custom/search": {
        "format": " ",
        "on-click": "wofi --show drun",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "persistent-workspaces": {
            "*": 4
        },
        "format-icons": {
            "1": "MAIN",
            "2": "SEC",
            "3": "NET",
            "4": "PRIV"
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 60,
        "separate-outputs": true
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    },

    "network": {
        "format-wifi": "  {signalStrength}%",
        "format-ethernet": "  {ifname}",
        "format-disconnected": "  OFF",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "  MUTE",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%a %b %d, %Y}",
        "tooltip-format": "<tt>{calendar}</tt>"
    }
}
